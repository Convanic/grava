# FollowSymLinks ist Voraussetzung für mod_rewrite. Manche Shared-Hoster
# haben es per Default aus — dann quittiert Apache jede RewriteRule mit
# einem 500. Falls der Hoster FollowSymLinks verbietet, stattdessen
# SymLinksIfOwnerMatch verwenden (s. README/Deploy-Doku).
Options -Indexes +FollowSymLinks
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Bearer-Auth: Viele CGI/FastCGI/LiteSpeed-Setups entfernen den
    # Authorization-Header, bevor er PHP erreicht -> $_SERVER hat dann kein
    # HTTP_AUTHORIZATION und jeder geschützte Endpunkt antwortet mit 401.
    # Diese Regel reicht den Header explizit als Env-Variable durch. Da das
    # Routing weiter unten einen internen Rewrite auf index.php macht, liest
    # die PHP-Seite zusätzlich REDIRECT_HTTP_AUTHORIZATION (s. Request.php).
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Optional HTTPS-Erzwingung in Produktion. In MAMP/lokal nicht aktiv,
    # da kein HTTPS-Zertifikat eingerichtet ist. Setze APP_ENV=production
    # und entferne die folgenden zwei Zeilen-Kommentare, um zu erzwingen.
    # RewriteCond %{HTTPS} !=on
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # index.php selbst nie weiter umschreiben (verhindert Endlosschleifen).
    RewriteRule ^index\.php$ - [L]
    RewriteRule ^\.well-known/ - [L]

    # Universal Links / RFC 5785: /.well-known/* immer als echtes Verzeichnis
    # ausliefern, NICHT auf index.php umleiten (sonst blockt der Hoster den
    # Dot-Pfad bzw. iOS bekommt kein gültiges application/json).
    RewriteRule ^\.well-known/ - [L]

    # Route alles, was nicht existiert, auf index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Security-Header
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # H3: HSTS — Browser sollen den Host für ein Jahr nur über HTTPS laden.
    # Apache liefert den Header laut `expr` nur über TLS aus, damit die
    # Direktive auch sicher ist, wenn jemand HTTP-Direktbetrieb fährt.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"

    # H3: Restriktive CSP — keine inline-Scripts, kein eval, alles aus
    # eigener Origin. Inline-Styles bleiben erlaubt, weil layout.php
    # einen kleinen <style>-Block nutzt; sobald der ausgelagert ist,
    # kann 'unsafe-inline' bei style-src entfallen.
    #
    # img-src erlaubt zusätzlich OSM-Raster-Tiles für die Leaflet-Karten
    # (Map-Tiles sind <img>-Elemente von einem fremden Host). Wechselt der
    # Tile-Provider, muss hier der neue Host eingetragen werden.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'"
</IfModule>

# Versteckte Dateien verbieten
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
