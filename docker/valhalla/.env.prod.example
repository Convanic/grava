# Kopie als .env.prod anlegen und Werte setzen. NICHT committen (siehe .gitignore).
#
#   cp .env.prod.example .env.prod
#   # Secret erzeugen:
#   openssl rand -hex 24

# Oeffentliche Domain, die per A-Record auf die Server-IP zeigt.
VALHALLA_DOMAIN=valhalla.grava.world

# Geheimer Pfad-Praefix-Token (NUR Hex/URL-sichere Zeichen). Muss exakt dem
# Wert in der Prod-VALHALLA_BASE_URL entsprechen.
VALHALLA_PROXY_SECRET=CHANGE_ME_openssl_rand_hex_24

# Optional: Region uebersteuern (Default in der compose = ganz Europa).
# VALHALLA_TILE_URLS=https://download.geofabrik.de/europe/germany-latest.osm.pbf

# Optional: Anzahl Serve-Threads (Default 4). Auf grossen Servern hoeher.
# VALHALLA_THREADS=8
