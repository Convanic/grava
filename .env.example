APP_ENV=production
APP_URL=https://gravelexplorer.benx.de
API_BASE_PATH=/api/v1
APP_KEY=

# Geheimer Token für die internen HTTP-Endpoints (Migration & Cron), die
# auf Hosting ohne SSH genutzt werden:
#   GET /internal/migrate?token=...
#   GET /internal/cron/cleanup?token=...
#   GET /internal/cron/heatmap?token=...
# Leer lassen = Endpoints deaktiviert (404). Langen Zufallswert verwenden,
# z. B. `php -r "echo bin2hex(random_bytes(24));"`.
INTERNAL_TOKEN=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gravelexplorer
DB_USER=
DB_PASS=
DB_SOCKET=

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@gravelexplorer.benx.de
MAIL_FROM_NAME=GravelExplorer
MAIL_ENCRYPTION=tls

ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=5184000
EMAIL_VERIFY_TTL=86400
PASSWORD_RESET_TTL=3600

RATE_LOGIN_MAX=10
RATE_REGISTER_MAX=10
RATE_FORGOT_MAX=5
RATE_VERIFY_RESEND_MAX=5
RATE_WINDOW_SECONDS=900

COOKIE_DOMAIN=gravelexplorer.benx.de
COOKIE_SECURE=true

# Web-Session sliding TTL (Phase 0). Sekunden; jede authentifizierte
# Aktion erneuert den Ablauf-Timer.
WEB_SESSION_TTL=1800

# M2: Wo liegen die Track-Payloads (GPX/GeoJSON-Files)?
# Default = <repo>/storage/routes. Pfad muss vom Webserver schreibbar sein.
STORAGE_ROUTES_DIR=

# M2 Phase 7: Soft-deleted Routen werden nach diesen Tagen vom
# cron:cleanup hart entfernt (DB + FS). Default 30. Auf 0 setzen
# = sofortiger Hard-Delete im nächsten Cleanup-Lauf.
ROUTES_SOFT_DELETE_GRACE_DAYS=30

# M4c: Gelesene Notifications werden nach diesen Tagen vom
# cron:cleanup entfernt. Default 90.
NOTIFICATIONS_READ_GRACE_DAYS=90

# M4d: Wo liegen die Profil-Avatare?
# Default = <repo>/storage/avatars. Pfad muss vom Webserver schreibbar sein.
STORAGE_AVATARS_DIR=

# M4e: Strava-Integration (OAuth2). Leer lassen = Integration nutzt den
# Fake-Client (Dev/Smoke, kein Netz). Für den Live-Betrieb die Werte aus
# der Strava-API-App eintragen. STRAVA_FAKE=1 erzwingt den Fake-Client
# auch bei gesetzter CLIENT_ID (lokales Testen).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
STRAVA_FAKE=

# M7: Empfehlungen / Referrals.
# Basis-URL für den Einlade-Link (https://<base>/i/{code}). Leer lassen =
# es wird APP_URL verwendet. In Produktion auf die Kurz-Domain setzen,
# z. B. https://grava.world.
REFERRAL_LINK_BASE=
# App-Store-Link auf der öffentlichen /i/{code}-Landingpage (optional).
APP_STORE_URL=
# Kommagetrennte E-Mail-Liste der Admins, die /admin/referrals (Werber-
# Auswertung + CSV) sehen dürfen. Leer = niemand (Seite liefert 404).
ADMIN_EMAILS=
