APP_ENV=production
APP_URL=https://gravelexplorer.benx.de
API_BASE_PATH=/api/v1
APP_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gravelexplorer
DB_USER=
DB_PASS=
DB_SOCKET=

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@gravelexplorer.benx.de
MAIL_FROM_NAME=GravelExplorer
MAIL_ENCRYPTION=tls

ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=5184000
EMAIL_VERIFY_TTL=86400
PASSWORD_RESET_TTL=3600

RATE_LOGIN_MAX=10
RATE_REGISTER_MAX=10
RATE_FORGOT_MAX=5
RATE_VERIFY_RESEND_MAX=5
RATE_WINDOW_SECONDS=900

COOKIE_DOMAIN=gravelexplorer.benx.de
COOKIE_SECURE=true
